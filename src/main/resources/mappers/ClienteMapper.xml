<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="edu.unisabana.dyas.sampleprj.dao.mybatis.mappers.ClienteMapper">

    <!-- ============================================================
         ResultMap para TipoItem
         Tabla: VI_TIPOITEM  →  columnas con prefijo "ti_"
    ============================================================ -->
    <resultMap type="TipoItem" id="TipoItemResult">
        <id     property="id"          column="ti_id"/>
        <result property="descripcion"  column="ti_descripcion"/>
    </resultMap>

    <!-- ============================================================
         ResultMap para Item
         Tabla: VI_ITEMS  →  columnas con prefijo "i_"
         Tiene asociación uno-a-uno con TipoItem (prefijo "ti_")
    ============================================================ -->
    <resultMap type="Item" id="ItemResult">
        <id     property="id"               column="i_id"/>
        <result property="nombre"           column="i_nombre"/>
        <result property="descripcion"      column="i_descripcion"/>
        <result property="fechaLanzamiento" column="i_fechalanzamiento"/>
        <result property="tarifaxDia"       column="i_tarifaxdia"/>
        <result property="formatoRenta"     column="i_formatorenta"/>
        <result property="genero"           column="i_genero"/>
        <association property="tipo" javaType="TipoItem" resultMap="TipoItemResult" columnPrefix="ti_"/>
    </resultMap>

    <!-- ============================================================
         ResultMap para ItemRentado
         Tabla: VI_ITEMRENTADO  →  columnas con prefijo "ir_"
         Tiene asociación uno-a-uno con Item (prefijo "i_")
    ============================================================ -->
    <resultMap type="ItemRentado" id="ItemRentadoResult">
        <id     property="id"               column="ir_id"/>
        <result property="fechainiciorenta" column="ir_fechainiciorenta"/>
        <result property="fechafinrenta"    column="ir_fechafinrenta"/>
        <association property="item" javaType="Item" resultMap="ItemResult" columnPrefix="i_"/>
    </resultMap>

    <!-- ============================================================
         ResultMap para Cliente
         Tabla: VI_CLIENTES  →  columnas sin prefijo (tabla raíz)
         Tiene colección uno-a-muchos de ItemRentado (prefijo "ir_")
    ============================================================ -->
    <resultMap type="Cliente" id="ClienteResult">
        <id     property="documento"  column="documento"/>
        <result property="nombre"     column="nombre"/>
        <result property="telefono"   column="telefono"/>
        <result property="direccion"  column="direccion"/>
        <result property="email"      column="email"/>
        <result property="vetado"     column="vetado"/>
        <collection property="rentados"
                    ofType="ItemRentado"
                    resultMap="ItemRentadoResult"
                    columnPrefix="ir_"/>
    </resultMap>

    <!-- ============================================================
         Query: consultarClientes — trae TODOS los clientes con sus items
         Alias con prefijos anidados para evitar colisión de nombres
    ============================================================ -->
    <select id="consultarClientes" resultMap="ClienteResult">
        SELECT
            c.nombre,
            c.documento,
            c.telefono,
            c.direccion,
            c.email,
            c.vetado,
            ir.CLIENTES_documento  AS ir_id,
            ir.fechainiciorenta    AS ir_fechainiciorenta,
            ir.fechafinrenta       AS ir_fechafinrenta,
            i.id                   AS ir_i_id,
            i.nombre               AS ir_i_nombre,
            i.descripcion          AS ir_i_descripcion,
            i.fechalanzamiento     AS ir_i_fechalanzamiento,
            i.tarifaxdia           AS ir_i_tarifaxdia,
            i.formatorenta         AS ir_i_formatorenta,
            i.genero               AS ir_i_genero,
            ti.id                  AS ir_i_ti_id,
            ti.descripcion         AS ir_i_ti_descripcion
        FROM VI_CLIENTES AS c
        LEFT JOIN VI_ITEMRENTADO AS ir ON c.documento = ir.CLIENTES_documento
        LEFT JOIN VI_ITEMS       AS i  ON ir.ITEMS_id = i.id
        LEFT JOIN VI_TIPOITEM    AS ti ON i.TIPOITEM_id = ti.id
    </select>

    <!-- ============================================================
         Query: consultarCliente — trae UN cliente por documento
    ============================================================ -->
    <select id="consultarCliente" parameterType="int" resultMap="ClienteResult">
        SELECT
            c.nombre,
            c.documento,
            c.telefono,
            c.direccion,
            c.email,
            c.vetado,
            ir.CLIENTES_documento  AS ir_id,
            ir.fechainiciorenta    AS ir_fechainiciorenta,
            ir.fechafinrenta       AS ir_fechafinrenta,
            i.id                   AS ir_i_id,
            i.nombre               AS ir_i_nombre,
            i.descripcion          AS ir_i_descripcion,
            i.fechalanzamiento     AS ir_i_fechalanzamiento,
            i.tarifaxdia           AS ir_i_tarifaxdia,
            i.formatorenta         AS ir_i_formatorenta,
            i.genero               AS ir_i_genero,
            ti.id                  AS ir_i_ti_id,
            ti.descripcion         AS ir_i_ti_descripcion
        FROM VI_CLIENTES AS c
        LEFT JOIN VI_ITEMRENTADO AS ir ON c.documento = ir.CLIENTES_documento
        LEFT JOIN VI_ITEMS       AS i  ON ir.ITEMS_id = i.id
        LEFT JOIN VI_TIPOITEM    AS ti ON i.TIPOITEM_id = ti.id
        WHERE c.documento = #{id}
    </select>

</mapper>
